<Window x:Class="TaxiService.WPF.StatusChangeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="✏️ Изменить статус водителя" Height="180" Width="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,41" Grid.RowSpan="2">
            <TextBlock Text="Выберите новый статус:" Margin="0,0,0,10" FontWeight="SemiBold" FontSize="14"/>
            <ComboBox x:Name="cbStatus" Height="31" FontSize="13" VerticalContentAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="✅ OK" Width="80" Height="35" Margin="0,0,10,0"
                    Click="BtnOk_Click" Style="{StaticResource PrimaryButton}"/>
            <Button Content="❌ Отмена" Width="80" Height="35"
                    Click="BtnCancel_Click" Background="#E0E0E0" Foreground="Black"/>
        </StackPanel>
    </Grid>
</Window>